{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      }
    }
  },
  "instructions": [
    ".opencode/instructions/coding-standards.md",
    ".opencode/instructions/frontend-patterns.md",
    ".opencode/instructions/verification-loop.md",
    ".opencode/instructions/api-design.md",
    ".opencode/instructions/security-review.md"
  ],
  "agent": {
    "code-reviewer": {
      "promptFile": ".opencode/agents/code-reviewer.md",
      "tools": {
        "Read": true,
        "Grep": true,
        "Glob": true,
        "Edit": true,
        "Bash": true,
        "WebSearch": true
      }
    },
    "build-error-resolver": {
      "promptFile": ".opencode/agents/build-error-resolver.md",
      "tools": {
        "Read": true,
        "Bash": true,
        "Grep": true,
        "Glob": true,
        "WebSearch": true
      }
    },
    "refactor-cleaner": {
      "promptFile": ".opencode/agents/refactor-cleaner.md",
      "tools": {
        "Read": true,
        "Grep": true,
        "Glob": true,
        "Edit": true,
        "Bash": true
      }
    },
    "tdd-guide": {
      "promptFile": ".opencode/agents/tdd-guide.md",
      "tools": {
        "Read": true,
        "Edit": true,
        "Bash": true,
        "Grep": true,
        "Glob": true,
        "WebSearch": true
      }
    }
  },
  "command": {
    "plan": {
      "description": "Create an implementation plan for a feature or change",
      "template": ".opencode/commands/plan.md",
      "model": "anthropic/claude-sonnet-4-5",
      "tools": [
        "Read",
        "Grep",
        "Glob",
        "WebSearch"
      ]
    },
    "verify": {
      "description": "Run verification loop: lint, typecheck, build",
      "template": ".opencode/commands/verify.md",
      "tools": [
        "Bash",
        "Read"
      ]
    },
    "code-review": {
      "description": "Review staged or working changes for quality and security",
      "template": ".opencode/commands/code-review.md",
      "tools": [
        "Bash",
        "Read",
        "Grep",
        "Glob",
        "WebSearch"
      ]
    },
    "refactor-clean": {
      "description": "Find and remove dead code, unused exports, loose files",
      "template": ".opencode/commands/refactor-clean.md",
      "tools": [
        "Grep",
        "Glob",
        "Read",
        "Edit",
        "Bash"
      ]
    },
    "goal": {
      "description": "Set a high-level objective for the session (like Claude Code's /goal)",
      "template": ".opencode/commands/goal.md",
      "model": "anthropic/claude-sonnet-4-5"
    }
  }
}